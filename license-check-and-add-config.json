{
    "license": "header.txt",
    "ignoreFile": ".gitignore",
    "ignore": [
        "ios/**",
        "android/**",
        ".expo/**",
        "dist/**",
        "build/**",
        "package.json",
        "tsconfig.json",
        "eas.json",
        "expo-env.d.ts",
        "uniwind-types.d.ts",
        "license-check-and-add-config.json",
        "header.txt",
        "LICENSE",
        "README.md",
        "global.css",
        "web-preview/preview-plugins.json",
        "web-preview/Dockerfile",
        "release-manifest.json",
        "release/mobile-preview-release.template.json",
        "version.json"
    ],
    "licenseFormats": {
        "d.ts|md": {
            "prepend": "/*",
            "append": "*/"
        },
        "yml|yaml|npmrc": {
            "eachLine": {
                "prepend": "# "
            }
        }
    },
    "trailingWhitespace": "TRIM"
}
