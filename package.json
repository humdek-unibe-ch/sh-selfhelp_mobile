{
    "name": "selfhelp-mobile",
    "version": "0.1.0",
    "private": true,
    "main": "expo-router/entry",
    "scripts": {
        "start": "expo start",
        "start:clean": "expo start --clear",
        "android": "expo run:android",
        "ios": "expo run:ios",
        "web": "expo start --web",
        "web:build": "expo export -p web",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "typecheck": "tsc --noEmit",
        "build:dev:android": "eas build -p android --profile development",
        "build:preview:android": "eas build -p android --profile preview",
        "build:prod:android": "node scripts/validate-instance.mjs production && eas build -p android --profile production",
        "build:dev:ios": "eas build -p ios --profile development",
        "build:preview:ios": "eas build -p ios --profile preview",
        "build:prod:ios": "node scripts/validate-instance.mjs production && eas build -p ios --profile production",
        "submit:android": "eas submit -p android",
        "submit:ios": "eas submit -p ios",
        "update:dev": "eas update --branch development",
        "update:prod": "eas update --branch production",
        "instance:add": "node scripts/add-instance.mjs",
        "instance:validate": "node scripts/validate-instance.mjs",
        "test": "node --test \"__tests__/**/*.test.mjs\""
    },
    "dependencies": {
        "@gorhom/bottom-sheet": "^5.2.8",
        "@hookform/resolvers": "^5.2.2",
        "@react-native-async-storage/async-storage": "3.0.2",
        "@react-navigation/drawer": "^7.5.0",
        "@selfhelp/shared": "file:../sh-selfhelp_shared",
        "@tanstack/query-async-storage-persister": "^5.100.9",
        "@tanstack/react-query": "^5.100.9",
        "@tanstack/react-query-persist-client": "^5.100.9",
        "axios": "^1.16.0",
        "expo": "~55.0.23",
        "expo-asset": "~55.0.17",
        "expo-audio": "~55.0.14",
        "expo-camera": "~55.0.18",
        "expo-constants": "~55.0.16",
        "expo-device": "~55.0.16",
        "expo-image": "~55.0.10",
        "expo-image-picker": "~55.0.20",
        "expo-linking": "~55.0.15",
        "expo-localization": "~55.0.13",
        "expo-media-library": "~55.0.16",
        "expo-notifications": "~55.0.22",
        "expo-router": "~55.0.14",
        "expo-secure-store": "~55.0.13",
        "expo-splash-screen": "~55.0.20",
        "expo-status-bar": "~55.0.6",
        "expo-system-ui": "~55.0.17",
        "expo-updates": "~55.0.21",
        "expo-video": "~55.0.16",
        "heroui-native": "^1.0.2",
        "i18next": "^26.0.9",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "react-hook-form": "^7.75.0",
        "react-i18next": "^17.0.6",
        "react-native": "0.85.3",
        "react-native-gesture-handler": "~2.31.2",
        "react-native-markdown-display": "^7.0.2",
        "react-native-reanimated": "~4.3.0",
        "react-native-render-html": "^6.3.4",
        "react-native-safe-area-context": "5.7.0",
        "react-native-screens": "~4.24.0",
        "react-native-sse": "^1.2.1",
        "react-native-svg": "15.15.4",
        "react-native-web": "~0.21.2",
        "react-native-worklets": "0.8.1",
        "tailwind-merge": "^3.4.0",
        "tailwind-variants": "^3.2.2",
        "uniwind": "^1.6.4",
        "zod": "^4.4.3",
        "zustand": "^5.0.13"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@types/react": "~19.2.14",
        "eslint": "^9.32.0",
        "eslint-config-expo": "~55.0.0",
        "typescript": "~5.9.3"
    },
    "engines": {
        "node": ">=20"
    }
}
