# Optional environment overrides for `expo start`.
# Copy to `.env.local` and edit as needed. All variables are read in
# `app.config.ts`. EAS Build profiles in `eas.json` provide their own
# values for production.

# APP_INSTANCE_SLUG=dev
# APP_BACKEND_URL=https://api.example.com
# APP_SERVER_SELECTION_URL=https://tpf-test.humdek.unibe.ch/SelfHelpMobile/mobile_projects
# APP_NAME_OVERRIDE=SelfHelp Dev
# APP_BUNDLE_ID=com.selfhelp.dev
# APP_PACKAGE_NAME=com.selfhelp.dev
# APP_SCHEME=selfhelp
# APP_UNIVERSAL_LINK_DOMAIN=app.example.com
# APP_EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000
# APP_EAS_UPDATE_URL=
